# ============================================================
# Future Leaders — Environment Variables
# ============================================================
# HOW TO FIND THESE VALUES:
#   1. Go to https://supabase.com and open your project
#   2. Click "Project Settings" (gear icon, bottom-left)
#   3. Go to "API" tab
#   4. Copy the values below from that page
# ============================================================

# Your Supabase project URL  (looks like: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Your Supabase anon/public key  (safe to use in the browser)
VITE_SUPABASE_ANON_KEY=

# ============================================================
# IMPORTANT:
#   - Never share or commit your service_role key (not needed here)
#   - VITE_ prefix is required for Vite to expose vars to the browser
#   - After filling in, restart the dev server: npm run dev
# ============================================================
